{
  "expo": {
    "name": "Bako - Car Component AI",
    "slug": "bako-car",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bako.car"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0F0F"
      },
      "package": "com.bako.car",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Bako to access your camera to scan car components."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Bako to access your photos to upload car component images."
        }
      ],
      "expo-router"
    ],
    "extra": {
      "supabaseUrl": "https://your-project-id.supabase.co",
      "supabaseKey": "your-anon-key",
      "apiUrl": "http://localhost:8000/api"
    }
  }
}
